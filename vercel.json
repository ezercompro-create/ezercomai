{
  "regions": ["fra1"],
  "rewrites": [
    { "source": "/bx/:path*", "destination": "https://fapi.binance.com/:path*" },
    { "source": "/by/:path*", "destination": "https://api.bybit.com/:path*" },
    { "source": "/yh/:path*", "destination": "https://query1.finance.yahoo.com/:path*" }
  ],
  "functions": {
    "api/scan.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/scan", "schedule": "30 0 * * *" }
  ]
}
